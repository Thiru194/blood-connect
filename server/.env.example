# Copy this file to ".env" and fill in real values.

# Port the API server listens on
PORT=5000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/bloodconnect

# Secret used to sign JWT auth tokens (use a long random string)
JWT_SECRET=replace_with_a_long_random_secret

# (Production, optional) The deployed frontend URL. When set, the API only
# accepts requests from this origin. Leave unset for local development.
# Example: https://blood-connect.vercel.app
CLIENT_URL=
